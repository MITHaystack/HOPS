#!/bin/bash

#this script is to be called by cmake-tests in the <build>/test_data directory
#after the tarballs have been copied in

EXPECTED=8
CHECK_OUTPUT=$(sha256sum --check SHA256SUMS.txt 2>&1)
NVALID=$(echo "$CHECK_OUTPUT" | grep -c ": OK$")

RET_VAL=1 #script return value, default to bad
if [[ "$NVALID" == "$EXPECTED" ]]; then
  RET_VAL=0 #all good
  echo "Test data checksums valid."
else
  echo "Test data checksum verification FAILED: $NVALID of $EXPECTED files OK."
  echo ""
  echo "Failing files:"
  # Report any file that did not produce an OK line
  echo "$CHECK_OUTPUT" | grep -v ": OK$"
  echo ""
  echo "Expected vs. actual checksums for failing files:"
  while read -r expected_sum file; do
    # Strip leading "./" if present for cleaner matching
    if [[ -f "$file" ]]; then
      actual_sum=$(sha256sum "$file" | awk '{print $1}')
      if [[ "$actual_sum" != "$expected_sum" ]]; then
        echo "  $file"
        echo "    expected: $expected_sum"
        echo "    actual:   $actual_sum"
      fi
    else
      echo "  $file"
      echo "    expected: $expected_sum"
      echo "    actual:   <file not found>"
    fi
  done < SHA256SUMS.txt
fi

exit $RET_VAL
